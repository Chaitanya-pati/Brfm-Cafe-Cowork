@model co_working.Models.CoworkingData
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Co-Working Space &amp; Memberships — Brew &amp; Work, Belagavi</title>
    <meta name="description" content="Flexible co-working memberships in Belagavi — daily, weekly and monthly hot desk plans. High-speed internet, meeting room, and a cafe next door. Open Mon–Sat, 9 AM–9 PM. On Bauxite Road, Valbhay Nagar.">
    <meta name="keywords" content="co-working space Belagavi, hot desk Belagavi, shared office Belagavi, meeting room Belagavi, coworking Belagavi, flexible workspace Karnataka">
    <meta name="robots" content="index, follow">
    <meta name="author" content="Brew &amp; Work">
    <link rel="canonical" href="https://brewandwork.in/coworking">

    <meta property="og:type" content="website">
    <meta property="og:title" content="Co-Working Space &amp; Memberships — Brew &amp; Work, Belagavi">
    <meta property="og:description" content="Co-working space with daily, weekly and monthly plans. High-speed internet, meeting room, and a cafe next door. Open Mon–Sat, 9 AM–9 PM. Bauxite Road, Belagavi.">
    <meta property="og:url" content="https://brewandwork.in/coworking">
    <meta property="og:site_name" content="Brew &amp; Work">
    <meta property="og:locale" content="en_IN">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Co-Working Space — Brew &amp; Work, Belagavi">
    <meta name="twitter:description" content="Co-working with daily, weekly and monthly plans. High-speed internet, meeting room, cafe next door. Open Mon–Sat, 9 AM–9 PM. Bauxite Road, Belagavi.">

    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "CoWorkingSpace",
      "name": "Brew & Work — Co-Working",
      "description": "Flexible co-working space in Belagavi with daily, weekly, and monthly membership plans, meeting rooms, and high-speed internet. Open Mon–Sat, 9 AM–9 PM.",
      "url": "https://brewandwork.in/coworking",
      "telephone": "+919922557733",
      "address": {
        "@@type": "PostalAddress",
        "streetAddress": "Bauxite Road, Valbhay Nagar",
        "addressLocality": "Belagavi",
        "addressRegion": "Karnataka",
        "addressCountry": "IN"
      },
      "openingHoursSpecification": {
        "@@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
        "opens": "09:00",
        "closes": "21:00"
      },
      "amenityFeature": [
        {"@@type": "LocationFeatureSpecification", "name": "High-Speed Wi-Fi", "value": true},
        {"@@type": "LocationFeatureSpecification", "name": "Meeting Room", "value": true},
        {"@@type": "LocationFeatureSpecification", "name": "Cafe On-Site", "value": true}
      ]
    }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/styles.css">
    <link rel="stylesheet" href="~/css/pages.css">
</head>
<body class="cowork-body">
    <header class="header header-solid">
        <div class="header-container">
            <a href="/" class="logo">
                <span class="logo-icon">&#9827;</span>
                <span class="logo-text">Brew &amp; Work</span>
            </a>
            <nav class="nav">
                <button class="nav-toggle" aria-label="Toggle navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <ul class="nav-menu">
                    <li><a asp-controller="Pages" asp-action="Index" class="nav-link">Home</a></li>
                    <li><a asp-controller="Pages" asp-action="Cafe" class="nav-link">Cafe</a></li>
                    <li><a asp-controller="Pages" asp-action="Coworking" class="nav-link active">Co-Working</a></li>
                    <li><a href="#contact" class="nav-link">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero hero-cowork">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <h1 class="hero-title">@Model.Hero.Title</h1>
                <p class="hero-subtitle">@Model.Hero.Subtitle</p>
            </div>
        </section>

        <section class="section section-light cw-about-section">
            <div class="container">
                <div class="cw-about-grid">
                    <div class="cw-about-image">
                        <img src="~/Images/coworkImage.jpg" alt="HungryDad Co-Working Space" class="cw-space-img" />
                    </div>
                    <div class="cw-about-text">
                        <span class="cw-about-eyebrow">@Model.About.Eyebrow</span>
                        <p class="cw-about-desc">@Model.About.Description</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-cowork-themed">
            <div class="container">
                <div class="cw-plans-header">
                    <span class="cw-plans-eyebrow">@Model.PlansHeader.Eyebrow</span>
                    <h2 class="cw-plans-title">@Model.PlansHeader.Title</h2>
                    <div class="cw-plans-divider"></div>
                    <p class="cw-plans-sub">@Model.PlansHeader.Description</p>
                </div>

                @for (int i = 0; i < Model.Plans.Count; i++)
                {
                    var plan = Model.Plans[i];
                    <div class="cw-plan-block @plan.BlockClass">
                        @if (!plan.IsReversed)
                        {
                            <div class="cw-plan-text">
                                <span class="cw-plan-label">@plan.Name</span>
                                <p class="cw-plan-desc">@plan.Description</p>
                                <div class="cw-plan-rates">
                                    @foreach (var rate in plan.Rates)
                                    {
                                        <div class="cw-rate-item">
                                            <span class="cw-rate-label">@rate.Label</span>
                                            <span class="cw-rate-price">@rate.Price@if (!string.IsNullOrEmpty(rate.Period)){<span class="cw-rate-period">@rate.Period</span>}</span>
                                        </div>
                                    }
                                </div>
                                <a href="@plan.CtaHref" class="@plan.CtaClass">@plan.CtaText</a>
                            </div>
                            <div class="cw-plan-visual @plan.VisualClass">
                                <div class="cw-visual-icon">@Html.Raw(plan.Icon)</div>
                                <p>@plan.VisualLabel</p>
                            </div>
                        }
                        else
                        {
                            <div class="cw-plan-visual @plan.VisualClass">
                                <div class="cw-visual-icon">@Html.Raw(plan.Icon)</div>
                                <p>@plan.VisualLabel</p>
                            </div>
                            <div class="cw-plan-text">
                                <span class="cw-plan-label">@plan.Name</span>
                                <p class="cw-plan-desc">@plan.Description</p>
                                <div class="cw-plan-rates">
                                    @foreach (var rate in plan.Rates)
                                    {
                                        <div class="cw-rate-item">
                                            <span class="cw-rate-label">@rate.Label</span>
                                            <span class="cw-rate-price">@rate.Price@if (!string.IsNullOrEmpty(rate.Period)){<span class="cw-rate-period">@rate.Period</span>}</span>
                                        </div>
                                    }
                                </div>
                                <a href="@plan.CtaHref" class="@plan.CtaClass">@plan.CtaText</a>
                            </div>
                        }
                    </div>
                    if (i < Model.Plans.Count - 1)
                    {
                        <div class="cw-plan-divider"></div>
                    }
                }
            </div>
        </section>

        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">What's Included</h2>
                    <p class="section-subtitle">Complimentary with every membership plan</p>
                </div>

                <div class="amenities-grid amenities-grid-5">
                    @foreach (var amenity in Model.Amenities)
                    {
                        <div class="amenity-card">
                            <div class="amenity-icon">
                                @Html.Raw(amenity.Icon)
                            </div>
                            <h3>@amenity.Name</h3>
                            <p>@amenity.Description</p>
                        </div>
                    }
                </div>
            </div>
        </section>

        <partial name="_Contact" />
    </main>

    <partial name="_Footer" />

    <script src="~/js/main.js"></script>

    <partial name="_ChatWidget" />
</body>
</html>
