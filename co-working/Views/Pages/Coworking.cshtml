@{
    Layout = null;
}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Co-Working - Brew & Work</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/styles.css">
    <link rel="stylesheet" href="~/css/pages.css">
</head>
<body class="cowork-body">
    <header class="header header-solid">
        <div class="header-container">
            <a href="/" class="logo">
                <span class="logo-icon">&#9827;</span>
                <span class="logo-text">Brew & Work</span>
            </a>
            <nav class="nav">
                <button class="nav-toggle" aria-label="Toggle navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <ul class="nav-menu">
                    <li><a asp-controller="Pages" asp-action="Index" class="nav-link active">Home</a></li>
                    <li><a asp-controller="Pages" asp-action="Cafe" class="nav-link">Cafe</a></li>
                    <li><a asp-controller="Pages" asp-action="Coworking" class="nav-link">Co-Working</a></li>
                    <li><a href="#contact" class="nav-link">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero hero-cowork">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <h1 class="hero-title">Co-Working Space</h1>
                <p class="hero-subtitle">Where productivity meets inspiration</p>
            </div>
        </section>

        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Workspace Options</h2>
                    <p class="section-subtitle">Flexible plans designed for every professional need</p>
                </div>

                <div class="pricing-grid">
                    <div class="pricing-card">
                        <div class="pricing-header">
                            <h3>Day Pass</h3>
                            <div class="price">
                                <span class="currency">₹</span>
                                <span class="amount">499</span>
                                <span class="period">/day</span>
                            </div>
                        </div>
                        <ul class="pricing-features">
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Access to open workspace
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                High-speed WiFi
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Coffee & tea included
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                8AM - 8PM access
                            </li>
                        </ul>
                        <a href="#contact" class="btn btn-outline">Get Started</a>
                    </div>

                    <div class="pricing-card featured">
                        <div class="featured-badge">Most Popular</div>
                        <div class="pricing-header">
                            <h3>Monthly Flex</h3>
                            <div class="price">
                                <span class="currency">₹</span>
                                <span class="amount">4,999</span>
                                <span class="period">/month</span>
                            </div>
                        </div>
                        <ul class="pricing-features">
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Unlimited workspace access
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                High-speed WiFi
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Unlimited coffee & snacks
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                4 hours meeting room/month
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Printing (50 pages)
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Extended hours access
                            </li>
                        </ul>
                        <a href="#contact" class="btn btn-cowork">Get Started</a>
                    </div>

                    <div class="pricing-card">
                        <div class="pricing-header">
                            <h3>Dedicated Desk</h3>
                            <div class="price">
                                <span class="currency">₹</span>
                                <span class="amount">9,999</span>
                                <span class="period">/month</span>
                            </div>
                        </div>
                        <ul class="pricing-features">
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Your own dedicated desk
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Personal storage locker
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                24/7 access
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                8 hours meeting room/month
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Unlimited printing
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12" />
                                </svg>
                                Mail handling
                            </li>
                        </ul>
                        <a href="#contact" class="btn btn-outline">Get Started</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-cowork-themed">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Workspace Features</h2>
                    <p class="section-subtitle">Everything you need for productive work</p>
                </div>

                <div class="amenities-grid">
                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M8.111 16.404a5.5 5.5 0 0 1 7.778 0M12 20h.01M3 8l1.5 1.5L6 8l1.5 1.5L9 8l1.5 1.5L12 8l1.5 1.5L15 8l1.5 1.5L18 8l1.5 1.5L21 8v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8z" />
                            </svg>
                        </div>
                        <h3>Ultra-Fast WiFi</h3>
                        <p>1Gbps fiber internet for seamless work</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                        </div>
                        <h3>Meeting Rooms</h3>
                        <p>Private rooms with video conferencing</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                                <line x1="12" y1="18" x2="12.01" y2="18" />
                            </svg>
                        </div>
                        <h3>Phone Booths</h3>
                        <p>Soundproof pods for private calls</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="6 9 6 2 18 2 18 9" />
                                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                                <rect x="6" y="14" width="12" height="8" />
                            </svg>
                        </div>
                        <h3>Print & Scan</h3>
                        <p>Professional printing and scanning</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 8h1a4 4 0 0 1 0 8h-1" />
                                <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z" />
                                <line x1="6" y1="1" x2="6" y2="4" />
                                <line x1="10" y1="1" x2="10" y2="4" />
                                <line x1="14" y1="1" x2="14" y2="4" />
                            </svg>
                        </div>
                        <h3>Cafe Access</h3>
                        <p>Complimentary coffee and refreshments</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </div>
                        <h3>Secure Access</h3>
                        <p>24/7 keycard entry and security</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Operating Hours</h2>
                </div>

                <div class="hours-card glass-card cowork-hours">
                    <div class="hours-row">
                        <span>General Access</span>
                        <span>8:00 AM - 10:00 PM Daily</span>
                    </div>
                    <div class="hours-row">
                        <span>Dedicated Desk Members</span>
                        <span>24/7 Access</span>
                    </div>
                    <div class="hours-row">
                        <span>Reception</span>
                        <span>9:00 AM - 6:00 PM (Mon-Fri)</span>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer" id="contact">
        <div class="footer-container">
            <div class="footer-content">
                <div class="footer-brand">
                    <a href="/" class="footer-logo">
                        <span class="logo-icon">&#9827;</span>
                        <span class="logo-text">Brew & Work</span>
                    </a>
                    <p class="footer-tagline">Where coffee meets creativity</p>
                </div>
                <div class="footer-links">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/cafe.html">Cafe</a></li>
                        <li><a href="/coworking.html">Co-Working</a></li>
                    </ul>
                </div>
                <div class="footer-contact">
                    <h4>Contact Us</h4>
                    <p>123 Creative Avenue</p>
                    <p>contact@hungydad.in</p>
                    <p>(+91)  123-4567</p>
                </div>
                <div class="footer-social">
                    <h4>Follow Us</h4>
                    <div class="social-icons">
                        <a href="#" class="social-icon" aria-label="Facebook">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                            </svg>
                        </a>
                        <a href="#" class="social-icon" aria-label="Instagram">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                            </svg>
                        </a>
                        <a href="#" class="social-icon" aria-label="Twitter">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" />
                            </svg>
                        </a>
                        <a href="#" class="social-icon" aria-label="LinkedIn">
                            <svg viewBox="0 0 24 24" fill="currentColor">
                                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                <rect x="2" y="9" width="4" height="12" />
                                <circle cx="4" cy="4" r="2" />
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2025 Brew & Work. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="~/js/main.js"></script>
</body>

