@{
    Layout = null;
}
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Co-Working - Brew & Work</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/styles.css">
    <link rel="stylesheet" href="~/css/pages.css">
</head>
<body class="cowork-body">
    <header class="header header-solid">
        <div class="header-container">
            <a href="/" class="logo">
                <span class="logo-icon">&#9827;</span>
                <span class="logo-text">Brew & Work</span>
            </a>
            <nav class="nav">
                <button class="nav-toggle" aria-label="Toggle navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <ul class="nav-menu">
                    <li><a asp-controller="Pages" asp-action="Index" class="nav-link active">Home</a></li>
                    <li><a asp-controller="Pages" asp-action="Cafe" class="nav-link">Cafe</a></li>
                    <li><a asp-controller="Pages" asp-action="Coworking" class="nav-link">Co-Working</a></li>
                    <li><a href="#contact" class="nav-link">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero hero-cowork">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <h1 class="hero-title">Co-Working Space</h1>
                <p class="hero-subtitle">Where productivity meets inspiration</p>
            </div>
        </section>

        <!-- Intro Section -->
        <section class="section section-light">
            <div class="container">
                <div class="cw-intro-grid">
                    <div class="cw-intro-left">
                        <p>One size never fits all when it comes to working. Whether you are a creative freelancer, an entrepreneur, a student or a small team of business mavericks, we have a membership plan that will work for you.</p>
                    </div>
                    <div class="cw-intro-right">
                        <p>At HungryDad, every individual finds a home where work doesn't feel like work. Come to our vibrant space packed with natural light and greenery. Our co-working fuels productivity and collaboration.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Amenities + Booking -->
        <section class="section section-light cw-amenities-booking">
            <div class="container">
                <div class="cw-info-grid">
                    <div class="cw-amenities-block">
                        <h3 class="cw-block-title">Standard Amenities</h3>
                        <p class="cw-block-sub">With each of our membership plans you can enjoy the following facilities on a complimentary basis.</p>
                        <ul class="cw-amenities-list">
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                Air Conditioning
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                High Speed WiFi
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                Daily Housekeeping / Maintenance
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                Complimentary Coffee &amp; Tea
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                Printing Service at a fee
                            </li>
                        </ul>
                    </div>
                    <div class="cw-booking-block">
                        <h3 class="cw-block-title">Booking Details</h3>
                        <p class="cw-block-sub">For booking a spot at HungryDad Co-Work please get in touch with us directly.</p>
                        <div class="cw-contact-items">
                            <div class="cw-contact-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                </svg>
                                <a href="tel:+919922557733">+91 99225 57733</a>
                            </div>
                            <div class="cw-contact-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                    <polyline points="22,6 12,13 2,6"/>
                                </svg>
                                <a href="mailto:office@hungrydad.in">office@hungrydad.in</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Hot Desks -->
        <section class="section section-light">
            <div class="container">
                <div class="cw-plan-block cw-plan-hotdesk">
                    <div class="cw-plan-text">
                        <span class="cw-plan-label">Hot Desks</span>
                        <p class="cw-plan-desc">It is a single desk you can book for yourself on a daily basis. Flexible, no commitment, just show up and work.</p>
                        <div class="cw-plan-rates">
                            <div class="cw-rate-item">
                                <span class="cw-rate-label">Day Pass</span>
                                <span class="cw-rate-price">₹750</span>
                            </div>
                            <div class="cw-rate-item">
                                <span class="cw-rate-label">Week Pass</span>
                                <span class="cw-rate-price">₹2,500</span>
                            </div>
                            <div class="cw-rate-item">
                                <span class="cw-rate-label">Month Pass</span>
                                <span class="cw-rate-price">₹7,500</span>
                            </div>
                        </div>
                        <a href="#contact" class="btn btn-cowork">Book a Desk</a>
                    </div>
                    <div class="cw-plan-visual cw-visual-desk">
                        <div class="cw-visual-icon">
                            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" width="80" height="80">
                                <rect x="8" y="36" width="48" height="6" rx="2"/>
                                <rect x="14" y="42" width="4" height="14" rx="1"/>
                                <rect x="46" y="42" width="4" height="14" rx="1"/>
                                <rect x="12" y="16" width="40" height="20" rx="2"/>
                                <circle cx="32" cy="26" r="4"/>
                            </svg>
                        </div>
                        <p>Flexible workspace, your way</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Private Offices -->
        <section class="section section-cowork-themed">
            <div class="container">
                <div class="cw-plan-block cw-plan-private">
                    <div class="cw-plan-visual cw-visual-office">
                        <div class="cw-visual-icon">
                            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2" width="80" height="80">
                                <rect x="6" y="10" width="52" height="40" rx="3"/>
                                <path d="M6 26h52"/>
                                <rect x="14" y="34" width="10" height="16"/>
                                <rect x="40" y="34" width="10" height="16"/>
                                <path d="M28 50V38h8v12"/>
                                <rect x="3" y="50" width="58" height="4" rx="1"/>
                            </svg>
                        </div>
                        <p>Your team's private command centre</p>
                    </div>
                    <div class="cw-plan-text">
                        <span class="cw-plan-label">Private Offices</span>
                        <p class="cw-plan-desc">A plug and play space for your team. Lockable and only accessible by you and your team. This is a ready to go solution from day one.</p>
                        <div class="cw-plan-rates">
                            <div class="cw-rate-item">
                                <span class="cw-rate-label">4 Member</span>
                                <span class="cw-rate-price">₹20,000<span class="cw-rate-period">/mo</span></span>
                            </div>
                            <div class="cw-rate-item">
                                <span class="cw-rate-label">6 Member</span>
                                <span class="cw-rate-price">₹25,000<span class="cw-rate-period">/mo</span></span>
                            </div>
                            <div class="cw-rate-item">
                                <span class="cw-rate-label">8 Member</span>
                                <span class="cw-rate-price">₹30,000<span class="cw-rate-period">/mo</span></span>
                            </div>
                        </div>
                        <a href="#contact" class="btn btn-outline-light">Enquire Now</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-cowork-themed">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Workspace Features</h2>
                    <p class="section-subtitle">Everything you need for productive work</p>
                </div>

                <div class="amenities-grid">
                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M8.111 16.404a5.5 5.5 0 0 1 7.778 0M12 20h.01M3 8l1.5 1.5L6 8l1.5 1.5L9 8l1.5 1.5L12 8l1.5 1.5L15 8l1.5 1.5L18 8l1.5 1.5L21 8v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8z" />
                            </svg>
                        </div>
                        <h3>Ultra-Fast WiFi</h3>
                        <p>1Gbps fiber internet for seamless work</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                        </div>
                        <h3>Meeting Rooms</h3>
                        <p>Private rooms with video conferencing</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                                <line x1="12" y1="18" x2="12.01" y2="18" />
                            </svg>
                        </div>
                        <h3>Phone Booths</h3>
                        <p>Soundproof pods for private calls</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="6 9 6 2 18 2 18 9" />
                                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                                <rect x="6" y="14" width="12" height="8" />
                            </svg>
                        </div>
                        <h3>Print & Scan</h3>
                        <p>Professional printing and scanning</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 8h1a4 4 0 0 1 0 8h-1" />
                                <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z" />
                                <line x1="6" y1="1" x2="6" y2="4" />
                                <line x1="10" y1="1" x2="10" y2="4" />
                                <line x1="14" y1="1" x2="14" y2="4" />
                            </svg>
                        </div>
                        <h3>Cafe Access</h3>
                        <p>Complimentary coffee and refreshments</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </div>
                        <h3>Secure Access</h3>
                        <p>24/7 keycard entry and security</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="contact-section" id="contact">
            <div class="contact-container">
                <div class="contact-content">
                    <div class="contact-info">
                        <h2 class="contact-title">Get in Touch</h2>
                        <p class="contact-subtitle">Have questions or ready to book your space? We'd love to hear from you.</p>

                        <div class="contact-details">
                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                        <circle cx="12" cy="10" r="3" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Location</h4>
                                    <p>123 Creative Avenue<br>Bauxite Road, Valbhay Nagar<br>Beagavi, Karnataka</p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Phone</h4>
                                    <p><a href="tel:+911234567890">(+91) 123-456-7890</a></p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                        <polyline points="22,6 12,13 2,6" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Email</h4>
                                    <p>
                                        <a href="mailto:contact@brewandwork.com">contact@brewandwork.com</a><br>
                                        <a href="mailto:info@hungrydad.in">info@hungrydad.in</a>
                                    </p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <polyline points="12 6 12 12 16 14" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Hours</h4>
                                    <p>Cafe: 8 AM – 10 PM (Daily)<br>Co-Working: 24/7 Access Available</p>
                                </div>
                            </div>
                        </div>

                        <div class="social-links">
                            <a href="#" class="social-link" aria-label="Facebook">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="Instagram">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="Twitter">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="LinkedIn">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                    <rect x="2" y="9" width="4" height="12" />
                                    <circle cx="4" cy="4" r="2" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <div class="contact-form-wrapper">
                        <form class="contact-form">
                            <div class="form-group">
                                <label for="name">Full Name</label>
                                <input type="text" id="name" name="name" required placeholder="John Doe">
                            </div>

                            <div class="form-group">
                                <label for="email">Email Address</label>
                                <input type="email" id="email" name="email" required placeholder="john@example.com">
                            </div>

                            <div class="form-group">
                                <label for="phone">Phone Number</label>
                                <input type="tel" id="phone" name="phone" placeholder="+91 123-456-7890">
                            </div>

                            <div class="form-group">
                                <label for="interest">I'm interested in</label>
                                <select id="interest" name="interest" required>
                                    <option value="">Select an option</option>
                                    <option value="cafe">Cafe Services</option>
                                    <option value="coworking">Co-Working Space</option>
                                    <option value="both">Both Cafe & Co-Working</option>
                                    <option value="events">Private Events</option>
                                    <option value="other">Other Inquiry</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="message">Message</label>
                                <textarea id="message" name="message" rows="5" required placeholder="Tell us about your requirements..."></textarea>
                            </div>

                            <button type="submit" class="submit-btn">
                                Send Message
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <line x1="22" y1="2" x2="11" y2="13" />
                                    <polygon points="22 2 15 22 11 13 2 9 22 2" />
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <partial name="_Footer" />

    <script src="~/js/main.js"></script>
</body>

