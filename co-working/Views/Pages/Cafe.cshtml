@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cafe - Brew & Work</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/styles.css">
    <link rel="stylesheet" href="~/css/pages.css">
</head>
<body class="cafe-body">
    <header class="header header-solid">
        <div class="header-container">
            <a href="/" class="logo">
                <span class="logo-icon">&#9827;</span>
                <span class="logo-text">Brew & Work</span>
            </a>
            <nav class="nav">
                <button class="nav-toggle" aria-label="Toggle navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <ul class="nav-menu">
                    <li><a asp-controller="Pages" asp-action="Index" class="nav-link active">Home</a></li>
                    <li><a asp-controller="Pages" asp-action="Cafe" class="nav-link">Cafe</a></li>
                    <li><a asp-controller="Pages" asp-action="Coworking" class="nav-link">Co-Working</a></li>
                    <li><a href="#contact" class="nav-link">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero hero-cafe">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <h1 class="hero-title">Our Cafe</h1>
                <p class="hero-subtitle">Where every cup tells a story</p>
            </div>
        </section>

        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Our Menu</h2>
                    <p class="section-subtitle">Handcrafted with love and the finest ingredients</p>
                </div>

                <div class="menu-grid">
                    <div class="menu-category glass-card">
                        <div class="menu-icon">&#9749;</div>
                        <h3>Hot Beverages</h3>
                        <ul class="menu-items">
                            <li><span>Espresso</span><span>₹199</span></li>
                            <li><span>Americano</span><span>₹229</span></li>
                            <li><span>Cappuccino</span><span>₹259</span></li>
                            <li><span>Latte</span><span>₹289</span></li>
                            <li><span>Mocha</span><span>₹319</span></li>
                            <li><span>Hot Chocolate</span><span>₹259</span></li>
                        </ul>
                    </div>

                    <div class="menu-category glass-card">
                        <div class="menu-icon">&#127861;</div>
                        <h3>Cold Drinks</h3>
                        <ul class="menu-items">
                            <li><span>Iced Coffee</span><span>₹259</span></li>
                            <li><span>Cold Brew</span><span>₹289</span></li>
                            <li><span>Iced Latte</span><span>₹319</span></li>
                            <li><span>Frappe</span><span>₹349</span></li>
                            <li><span>Smoothies</span><span>₹379</span></li>
                            <li><span>Fresh Juice</span><span>₹319</span></li>
                        </ul>
                    </div>

                    <div class="menu-category glass-card">
                        <div class="menu-icon">&#127856;</div>
                        <h3>Pastries & Snacks</h3>
                        <ul class="menu-items">
                            <li><span>Croissant</span><span>₹199</span></li>
                            <li><span>Muffins</span><span>₹169</span></li>
                            <li><span>Banana Bread</span><span>₹229</span></li>
                            <li><span>Cheesecake</span><span>₹319</span></li>
                            <li><span>Cookies</span><span>₹149</span></li>
                            <li><span>Avocado Toast</span><span>₹449</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-cafe-themed">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Amenities</h2>
                    <p class="section-subtitle">Everything you need for the perfect cafe experience</p>
                </div>

                <div class="amenities-grid">
                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M8.111 16.404a5.5 5.5 0 0 1 7.778 0M12 20h.01M3 8l1.5 1.5L6 8l1.5 1.5L9 8l1.5 1.5L12 8l1.5 1.5L15 8l1.5 1.5L18 8l1.5 1.5L21 8v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8z" />
                            </svg>
                        </div>
                        <h3>Free WiFi</h3>
                        <p>High-speed internet for browsing and light work</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                                <line x1="3" y1="9" x2="21" y2="9" />
                                <line x1="9" y1="21" x2="9" y2="9" />
                            </svg>
                        </div>
                        <h3>Cozy Seating</h3>
                        <p>Comfortable sofas, armchairs, and window seats</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                            </svg>
                        </div>
                        <h3>Natural Light</h3>
                        <p>Large windows with beautiful city views</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M9 18V5l12-2v13" />
                                <circle cx="6" cy="18" r="3" />
                                <circle cx="18" cy="16" r="3" />
                            </svg>
                        </div>
                        <h3>Curated Music</h3>
                        <p>Relaxing ambient playlists for the perfect vibe</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                            </svg>
                        </div>
                        <h3>Book Corner</h3>
                        <p>A selection of books for reading enthusiasts</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="7" width="20" height="15" rx="2" ry="2" />
                                <polyline points="17 2 12 7 7 2" />
                            </svg>
                        </div>
                        <h3>Pet Friendly</h3>
                        <p>Your furry friends are welcome on our patio</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="contact-section" id="contact">
            <div class="contact-container">
                <div class="contact-content">
                    <div class="contact-info">
                        <h2 class="contact-title">Get in Touch</h2>
                        <p class="contact-subtitle">Have questions or ready to book your space? We'd love to hear from you.</p>

                        <div class="contact-details">
                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                        <circle cx="12" cy="10" r="3" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Location</h4>
                                    <p>123 Creative Avenue<br>Bauxite Road, Valbhay Nagar<br>Beagavi, Karnataka</p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Phone</h4>
                                    <p><a href="tel:+911234567890">(+91) 123-456-7890</a></p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                        <polyline points="22,6 12,13 2,6" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Email</h4>
                                    <p>
                                        <a href="mailto:contact@brewandwork.com">contact@brewandwork.com</a><br>
                                        <a href="mailto:info@hungrydad.in">info@hungrydad.in</a>
                                    </p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <polyline points="12 6 12 12 16 14" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Hours</h4>
                                    <p>Cafe: 8 AM – 10 PM (Daily)<br>Co-Working: 24/7 Access Available</p>
                                </div>
                            </div>
                        </div>

                        <div class="social-links">
                            <a href="#" class="social-link" aria-label="Facebook">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="Instagram">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="Twitter">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="LinkedIn">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                    <rect x="2" y="9" width="4" height="12" />
                                    <circle cx="4" cy="4" r="2" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <div class="contact-form-wrapper">
                        <form class="contact-form">
                            <div class="form-group">
                                <label for="name">Full Name</label>
                                <input type="text" id="name" name="name" required placeholder="John Doe">
                            </div>

                            <div class="form-group">
                                <label for="email">Email Address</label>
                                <input type="email" id="email" name="email" required placeholder="john@example.com">
                            </div>

                            <div class="form-group">
                                <label for="phone">Phone Number</label>
                                <input type="tel" id="phone" name="phone" placeholder="+91 123-456-7890">
                            </div>

                            <div class="form-group">
                                <label for="interest">I'm interested in</label>
                                <select id="interest" name="interest" required>
                                    <option value="">Select an option</option>
                                    <option value="cafe">Cafe Services</option>
                                    <option value="coworking">Co-Working Space</option>
                                    <option value="both">Both Cafe & Co-Working</option>
                                    <option value="events">Private Events</option>
                                    <option value="other">Other Inquiry</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="message">Message</label>
                                <textarea id="message" name="message" rows="5" required placeholder="Tell us about your requirements..."></textarea>
                            </div>

                            <button type="submit" class="submit-btn">
                                Send Message
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <line x1="22" y1="2" x2="11" y2="13" />
                                    <polygon points="22 2 15 22 11 13 2 9 22 2" />
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <partial name="_Footer" />

    <script src="~/js/main.js"></script>
</body>
</html>
