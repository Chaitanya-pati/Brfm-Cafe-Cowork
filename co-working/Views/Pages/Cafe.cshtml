@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cafe - Brew & Work</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Poppins:wght@300;400;500;600&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/styles.css">
    <link rel="stylesheet" href="~/css/pages.css">
</head>
<body class="cafe-body">
    <header class="header header-solid">
        <div class="header-container">
            <a href="/" class="logo">
                <span class="logo-icon">&#9827;</span>
                <span class="logo-text">Brew & Work</span>
            </a>
            <nav class="nav">
                <button class="nav-toggle" aria-label="Toggle navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <ul class="nav-menu">
                    <li><a asp-controller="Pages" asp-action="Index" class="nav-link active">Home</a></li>
                    <li><a asp-controller="Pages" asp-action="Cafe" class="nav-link">Cafe</a></li>
                    <li><a asp-controller="Pages" asp-action="Coworking" class="nav-link">Co-Working</a></li>
                    <li><a href="#contact" class="nav-link">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero hero-cafe">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <h1 class="hero-title">Our Cafe</h1>
                <p class="hero-subtitle">Where every cup tells a story</p>
            </div>
        </section>

        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Our Menu</h2>
                    <p class="section-subtitle">100% Pure Vegetarian &nbsp;·&nbsp; Handcrafted with love</p>
                </div>

                <div class="menu-grid">
                    <div class="menu-category glass-card">
                        <div class="menu-icon">&#9749;</div>
                        <h3>Hot Beverages</h3>
                        <ul class="menu-items">
                            <li><span>Espresso</span><span>₹130</span></li>
                            <li><span>Americano</span><span>₹130</span></li>
                            <li><span>Cappuccino</span><span>₹180 / ₹220</span></li>
                            <li><span>Machiatto</span><span>₹180</span></li>
                            <li><span>Latte</span><span>₹220</span></li>
                            <li><span>Flat White</span><span>₹220</span></li>
                            <li><span>Mocha</span><span>₹220</span></li>
                            <li><span>Hot Chocolate</span><span>₹180</span></li>
                            <li><span>Hibiscus Rose / Mint Tea</span><span>₹150</span></li>
                            <li><span>Matcha Classic</span><span>₹180</span></li>
                            <li><span>Matcha Strawberry</span><span>₹220</span></li>
                        </ul>
                        <p class="menu-addon">Add-on: Vanilla / Caramel / Hazelnut / Whipped Cream &nbsp;+₹50</p>
                    </div>

                    <div class="menu-category glass-card">
                        <div class="menu-icon">&#127862;</div>
                        <h3>Cold Beverages</h3>
                        <ul class="menu-items">
                            <li><span>Iced Americano</span><span>₹180</span></li>
                            <li><span>Iced Cappuccino</span><span>₹180</span></li>
                            <li><span>Iced Latte</span><span>₹180</span></li>
                            <li><span>Iced Flat White</span><span>₹220</span></li>
                            <li><span>Iced Mocha</span><span>₹220</span></li>
                            <li><span>Iced Machiatto</span><span>₹220</span></li>
                            <li><span>Iced Frapuccino</span><span>₹220</span></li>
                            <li><span>Cold Brew</span><span>₹180</span></li>
                            <li><span>Lemonade</span><span>₹180</span></li>
                            <li><span>Peach Coconut Refresher</span><span>₹180</span></li>
                            <li><span>Valencia Orange Juice</span><span>₹220</span></li>
                        </ul>
                        <p class="menu-addon">Oat / Almond Milk &nbsp;+₹60 &nbsp;·&nbsp; Extra Shot &nbsp;+₹60</p>
                    </div>

                    <div class="menu-category glass-card">
                        <div class="menu-icon">&#127859;</div>
                        <h3>Food</h3>
                        <ul class="menu-items">
                            <li><span>Chilli Cheese Toast</span><span>₹170</span></li>
                            <li><span>Marinara</span><span>₹140</span></li>
                            <li><span>Corn Sandwich</span><span>₹150</span></li>
                            <li><span>Chutney Sandwich</span><span>₹150</span></li>
                            <li><span>Korean Bun</span><span>₹150</span></li>
                            <li><span>Fresh Tomato Basil Soup</span><span>₹150</span></li>
                            <li><span>French Fries</span><span>₹150</span></li>
                            <li><span>Nachos &amp; Salsa</span><span>₹120</span></li>
                        </ul>
                    </div>
                </div>

                <!-- Specials Section -->
                <div class="specials-section">
                    <div class="specials-header">
                        <span class="specials-label">★ Chef's Specials ★</span>
                        <p>Signature dishes crafted fresh every day</p>
                    </div>
                    <div class="specials-grid">
                        <div class="special-item">
                            <div class="special-info">
                                <h4>Mediterranean Bowl</h4>
                                <p>Barley, pickled veggies, hummus and a host of seasonal produce</p>
                            </div>
                            <span class="special-price">₹220</span>
                        </div>
                        <div class="special-item">
                            <div class="special-info">
                                <h4>Granola Bowl</h4>
                                <p>In-house granola with nuts, oats, honey, greek yoghurt and seasonal fruits</p>
                            </div>
                            <span class="special-price">₹280</span>
                        </div>
                        <div class="special-item">
                            <div class="special-info">
                                <h4>Penne Arrabiata</h4>
                                <p>Pasta served with home made tomato basil sauce</p>
                            </div>
                            <span class="special-price">₹220</span>
                        </div>
                        <div class="special-item">
                            <div class="special-info">
                                <h4>Aglio e Olio</h4>
                                <p>Garlic, butter, chilli, parmesan — a smooth, spicy twist on the classic</p>
                            </div>
                            <span class="special-price">₹220</span>
                        </div>
                        <div class="special-item">
                            <div class="special-info">
                                <h4>Falafel Burger</h4>
                                <p>Crispy falafel with bold mediterranean vibes, flavours, freshness and crunch</p>
                            </div>
                            <span class="special-price">₹220</span>
                        </div>
                        <div class="special-item">
                            <div class="special-info">
                                <h4>Chia Seed Pudding</h4>
                                <p>Healthy all-day treat with chia seeds soaked in coconut milk and fruits</p>
                            </div>
                            <span class="special-price">₹180</span>
                        </div>
                        <div class="special-item">
                            <div class="special-info">
                                <h4>Cubano</h4>
                                <p>Bold espresso with a Cuban-style twist</p>
                            </div>
                            <span class="special-price">₹150</span>
                        </div>
                        <div class="special-item">
                            <div class="special-info">
                                <h4>Affogato</h4>
                                <p>Espresso poured over ice cream — simple, indulgent</p>
                            </div>
                            <span class="special-price">₹180</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-cafe-themed">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Amenities</h2>
                    <p class="section-subtitle">Everything you need for the perfect cafe experience</p>
                </div>

                <div class="amenities-grid">
                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12.55a11 11 0 0 1 14.08 0" />
                                <path d="M1.42 9a16 16 0 0 1 21.16 0" />
                                <path d="M8.53 16.11a6 6 0 0 1 6.95 0" />
                                <circle cx="12" cy="20" r="1" fill="currentColor" />
                            </svg>
                        </div>
                        <h3>Free WiFi</h3>
                        <p>High-speed internet for browsing and light work</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3" />
                                <path d="M2 11v5a2 2 0 0 0 2 2h1v2h2v-2h10v2h2v-2h1a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0H6a2 2 0 0 0-4 0z" />
                            </svg>
                        </div>
                        <h3>Cozy Seating</h3>
                        <p>Comfortable sofas, armchairs, and window seats</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="5" />
                                <line x1="12" y1="1" x2="12" y2="3" />
                                <line x1="12" y1="21" x2="12" y2="23" />
                                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                                <line x1="1" y1="12" x2="3" y2="12" />
                                <line x1="21" y1="12" x2="23" y2="12" />
                                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                            </svg>
                        </div>
                        <h3>Natural Light</h3>
                        <p>Large windows with beautiful city views</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                                <circle cx="12" cy="13" r="4" />
                            </svg>
                        </div>
                        <h3>Photo-friendly Space</h3>
                        <p>Aesthetic interiors and seating areas designed for great photos</p>
                    </div>

                    <div class="amenity-card">
                        <div class="amenity-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                            </svg>
                        </div>
                        <h3>Book Corner</h3>
                        <p>A selection of books for reading enthusiasts</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="contact-section" id="contact">
            <div class="contact-container">
                <div class="contact-content">
                    <div class="contact-info">
                        <h2 class="contact-title">Get in Touch</h2>
                        <p class="contact-subtitle">Have questions or ready to book your space? We'd love to hear from you.</p>

                        <div class="contact-details">
                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                        <circle cx="12" cy="10" r="3" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Location</h4>
                                    <p>123 Creative Avenue<br>Bauxite Road, Valbhay Nagar<br>Beagavi, Karnataka</p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Phone</h4>
                                    <p><a href="tel:+911234567890">(+91) 123-456-7890</a></p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                        <polyline points="22,6 12,13 2,6" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Email</h4>
                                    <p>
                                        <a href="mailto:contact@brewandwork.com">contact@brewandwork.com</a><br>
                                        <a href="mailto:info@hungrydad.in">info@hungrydad.in</a>
                                    </p>
                                </div>
                            </div>

                            <div class="contact-item">
                                <div class="contact-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <polyline points="12 6 12 12 16 14" />
                                    </svg>
                                </div>
                                <div class="contact-text">
                                    <h4>Hours</h4>
                                    <p>Cafe: 8 AM – 10 PM (Daily)<br>Co-Working: 24/7 Access Available</p>
                                </div>
                            </div>
                        </div>

                        <div class="social-links">
                            <a href="#" class="social-link" aria-label="Facebook">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="Instagram">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="Twitter">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z" />
                                </svg>
                            </a>
                            <a href="#" class="social-link" aria-label="LinkedIn">
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                    <rect x="2" y="9" width="4" height="12" />
                                    <circle cx="4" cy="4" r="2" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <div class="contact-form-wrapper">
                        <form class="contact-form">
                            <div class="form-group">
                                <label for="name">Full Name</label>
                                <input type="text" id="name" name="name" required placeholder="John Doe">
                            </div>

                            <div class="form-group">
                                <label for="email">Email Address</label>
                                <input type="email" id="email" name="email" required placeholder="john@example.com">
                            </div>

                            <div class="form-group">
                                <label for="phone">Phone Number</label>
                                <input type="tel" id="phone" name="phone" placeholder="+91 123-456-7890">
                            </div>

                            <div class="form-group">
                                <label for="interest">I'm interested in</label>
                                <select id="interest" name="interest" required>
                                    <option value="">Select an option</option>
                                    <option value="cafe">Cafe Services</option>
                                    <option value="coworking">Co-Working Space</option>
                                    <option value="both">Both Cafe & Co-Working</option>
                                    <option value="events">Private Events</option>
                                    <option value="other">Other Inquiry</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="message">Message</label>
                                <textarea id="message" name="message" rows="5" required placeholder="Tell us about your requirements..."></textarea>
                            </div>

                            <button type="submit" class="submit-btn">
                                Send Message
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <line x1="22" y1="2" x2="11" y2="13" />
                                    <polygon points="22 2 15 22 11 13 2 9 22 2" />
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <partial name="_Footer" />

    <script src="~/js/main.js"></script>
</body>
</html>
