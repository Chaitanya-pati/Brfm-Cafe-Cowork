@model co_working.Models.CafeData
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cafe - Brew &amp; Work</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/styles.css">
    <link rel="stylesheet" href="~/css/pages.css">
</head>
<body class="cafe-body">
    <header class="header header-solid">
        <div class="header-container">
            <a href="/" class="logo">
                <span class="logo-icon">&#9827;</span>
                <span class="logo-text">Brew &amp; Work</span>
            </a>
            <nav class="nav">
                <button class="nav-toggle" aria-label="Toggle navigation">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <ul class="nav-menu">
                    <li><a asp-controller="Pages" asp-action="Index" class="nav-link">Home</a></li>
                    <li><a asp-controller="Pages" asp-action="Cafe" class="nav-link active">Cafe</a></li>
                    <li><a asp-controller="Pages" asp-action="Coworking" class="nav-link">Co-Working</a></li>
                    <li><a href="#contact" class="nav-link">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero hero-cafe">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <h1 class="hero-title">@Model.Hero.Title</h1>
                <p class="hero-subtitle">@Model.Hero.Subtitle</p>
            </div>
        </section>

        <!-- Image Carousel -->
        <section class="cafe-carousel-section">
            <div class="cafe-carousel" id="cafeCarousel">
                <div class="carousel-track" id="carouselTrack">
                    <div class="carousel-slide">
                        <img src="/Images/cafeImg1.webp" alt="Brew &amp; Work Cafe" loading="eager" />
                    </div>
                    <div class="carousel-slide">
                        <img src="/Images/cafeImg2.webp" alt="Brew &amp; Work Cafe" loading="lazy" />
                    </div>
                    <div class="carousel-slide">
                        <img src="/Images/cafeImg3.webp" alt="Brew &amp; Work Cafe" loading="lazy" />
                    </div>
                    <div class="carousel-slide">
                        <img src="/Images/cafeImg4.webp" alt="Brew &amp; Work Cafe" loading="lazy" />
                    </div>
                    <div class="carousel-slide">
                        <img src="/Images/cafeImg5.webp" alt="Brew &amp; Work Cafe" loading="lazy" />
                    </div>
                </div>

                <div class="carousel-overlay-gradient"></div>

                <button class="carousel-btn carousel-btn-prev" id="carouselPrev" aria-label="Previous">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </button>
                <button class="carousel-btn carousel-btn-next" id="carouselNext" aria-label="Next">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"/>
                    </svg>
                </button>

                <div class="carousel-footer">
                    <div class="carousel-dots" id="carouselDots">
                        <button class="carousel-dot active" data-index="0" aria-label="Slide 1"></button>
                        <button class="carousel-dot" data-index="1" aria-label="Slide 2"></button>
                        <button class="carousel-dot" data-index="2" aria-label="Slide 3"></button>
                        <button class="carousel-dot" data-index="3" aria-label="Slide 4"></button>
                        <button class="carousel-dot" data-index="4" aria-label="Slide 5"></button>
                    </div>
                    <div class="carousel-counter">
                        <span id="carouselCurrent">1</span><span class="carousel-sep"> / </span><span>5</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-light">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Our Menu</h2>
                    <p class="section-subtitle">@Html.Raw(Model.MenuSubtitle)</p>
                </div>

                <div class="menu-grid">
                    @foreach (var category in Model.Categories)
                    {
                        <div class="menu-category glass-card">
                            <div class="menu-icon">
                                @Html.Raw(category.Icon)
                            </div>
                            <h3>@category.Name</h3>
                            <ul class="menu-items">
                                @foreach (var item in category.Items)
                                {
                                    <li><span>@item.Name</span><span>@item.Price</span></li>
                                }
                            </ul>
                            @if (!string.IsNullOrEmpty(category.Addon))
                            {
                                <p class="menu-addon">@Html.Raw(category.Addon)</p>
                            }
                        </div>
                    }
                </div>

                <div class="specials-section">
                    <div class="specials-header">
                        <span class="specials-label">&#9733; Chef's Specials &#9733;</span>
                        <p>Signature dishes crafted fresh every day</p>
                    </div>
                    <div class="specials-grid">
                        @foreach (var special in Model.Specials)
                        {
                            <div class="special-item">
                                <div class="special-info">
                                    <h4>@special.Name</h4>
                                    <p>@special.Description</p>
                                </div>
                                <span class="special-price">@special.Price</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-cafe-themed">
            <div class="container">
                <div class="section-header">
                    <h2 class="section-title">Amenities</h2>
                    <p class="section-subtitle">Everything you need for the perfect cafe experience</p>
                </div>

                <div class="amenities-grid">
                    @foreach (var amenity in Model.Amenities)
                    {
                        <div class="amenity-card">
                            <div class="amenity-icon">
                                @Html.Raw(amenity.Icon)
                            </div>
                            <h3>@amenity.Name</h3>
                            <p>@amenity.Description</p>
                        </div>
                    }
                </div>
            </div>
        </section>

        <partial name="_Contact" />
    </main>

    <partial name="_Footer" />

    <script src="~/js/main.js"></script>
    <script>
        (function () {
            const track = document.getElementById('carouselTrack');
            const slides = track.querySelectorAll('.carousel-slide');
            const dots = document.querySelectorAll('.carousel-dot');
            const counter = document.getElementById('carouselCurrent');
            const total = slides.length;
            let current = 0;
            let autoTimer = null;
            let isAnimating = false;
            let touchStartX = 0;
            let touchDeltaX = 0;
            let isDragging = false;

            function goTo(index, direction) {
                if (isAnimating) return;
                isAnimating = true;

                const prev = current;
                current = (index + total) % total;

                dots[prev].classList.remove('active');
                dots[current].classList.add('active');
                counter.textContent = current + 1;

                track.style.transition = 'transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
                track.style.transform = 'translateX(-' + (current * 100) + '%)';

                setTimeout(function () { isAnimating = false; }, 780);
            }

            function next() { goTo(current + 1); }
            function prev() { goTo(current - 1); }

            function startAuto() {
                stopAuto();
                autoTimer = setInterval(next, 4500);
            }

            function stopAuto() {
                clearInterval(autoTimer);
            }

            document.getElementById('carouselNext').addEventListener('click', function () {
                next(); startAuto();
            });
            document.getElementById('carouselPrev').addEventListener('click', function () {
                prev(); startAuto();
            });

            dots.forEach(function (dot) {
                dot.addEventListener('click', function () {
                    goTo(parseInt(dot.dataset.index));
                    startAuto();
                });
            });

            track.addEventListener('touchstart', function (e) {
                touchStartX = e.touches[0].clientX;
                isDragging = true;
                stopAuto();
                track.style.transition = 'none';
            }, { passive: true });

            track.addEventListener('touchmove', function (e) {
                if (!isDragging) return;
                touchDeltaX = e.touches[0].clientX - touchStartX;
                const base = -(current * 100);
                const drag = (touchDeltaX / track.parentElement.offsetWidth) * 100;
                track.style.transform = 'translateX(calc(' + base + '% + ' + touchDeltaX + 'px))';
            }, { passive: true });

            track.addEventListener('touchend', function () {
                isDragging = false;
                if (touchDeltaX < -50) next();
                else if (touchDeltaX > 50) prev();
                else goTo(current);
                touchDeltaX = 0;
                startAuto();
            });

            const carousel = document.getElementById('cafeCarousel');
            carousel.addEventListener('mouseenter', stopAuto);
            carousel.addEventListener('mouseleave', startAuto);

            startAuto();
        })();
    </script>
</body>
</html>
