@{
    Layout = null;
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brew & Work - Cafe & Co-Working</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://images.unsplash.com">
    <link rel="dns-prefetch" href="https://www.google.com">
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #000;
            color: #fff;
            overflow-x: hidden;
        }

        /* Header Styles */
        .header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            height: 70px;
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 40px;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: #fff;
            font-weight: 600;
            font-size: 18px;
            transition: opacity 0.3s ease;
        }

            .logo:hover {
                opacity: 0.8;
            }

        .logo-icon {
            font-size: 24px;
        }

        .logo-text {
            letter-spacing: 0.5px;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 35px;
            align-items: center;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.75);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            letter-spacing: 0.5px;
            transition: color 0.3s ease;
            position: relative;
        }

            .nav-link:hover,
            .nav-link.active {
                color: #fff;
            }

                .nav-link.active::after {
                    content: '';
                    position: absolute;
                    bottom: -8px;
                    left: 0;
                    right: 0;
                    height: 2px;
                    background: #fff;
                }

        .nav-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
        }

            .nav-toggle span {
                width: 24px;
                height: 2px;
                background: #fff;
                transition: all 0.3s ease;
            }

        /* Main Content */
        .split-screen {
            display: flex;
            min-height: 100vh;
            width: 100%;
            margin-top: 70px;
        }

        .panel {
            flex: 1;
            position: relative;
            background-size: cover;
            background-position: center;
            transition: flex 0.4s ease;
            cursor: pointer;
            height: calc(100vh - 70px);
        }

            .panel::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.7);
                z-index: 1;
            }

        .panel-cafe {
            background-image: url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1200&q=75&auto=format');
        }

        .panel-cowork {
            background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?w=1200&q=75&auto=format');
            border-left: 1px solid rgba(255, 255, 255, 0.12);
        }

        .panel:hover {
            flex: 1.03;
        }

        .panel-inner {
            position: absolute;
            inset: 0;
            z-index: 2;
            padding: 70px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* Brand Header inside panels */
        .brand-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 60px;
        }

        .logo-box {
            width: 40px;
            height: 40px;
            border: 2.5px solid #fff;
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .brand-name {
            font-size: 14.5px;
            font-weight: 400;
            letter-spacing: 0.3px;
            opacity: 0.95;
        }

        /* Content */
        .content {
            width: 100%;
        }

        .label {
            font-size: 11.5px;
            font-weight: 500;
            letter-spacing: 4px;
            opacity: 0.55;
            margin-bottom: 22px;
        }

        .title {
            font-family: 'Libre Baskerville', Georgia, serif;
            font-size: 54px;
            font-weight: 400;
            line-height: 1.05;
            margin-bottom: 26px;
            letter-spacing: -0.8px;
        }

        .description {
            font-size: 15px;
            line-height: 1.58;
            opacity: 0.88;
            font-weight: 400;
            margin-bottom: 32px;
            letter-spacing: 0.15px;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 9px;
            margin-bottom: 38px;
        }

        .tag {
            padding: 10px 18px;
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid rgba(255, 255, 255, 0.16);
            border-radius: 4px;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 1.2px;
            transition: all 0.25s ease;
            backdrop-filter: blur(8px);
        }

            .tag:hover {
                background: rgba(255, 255, 255, 0.14);
                border-color: rgba(255, 255, 255, 0.28);
            }

        .tag-special {
            background: rgba(30, 120, 255, 0.22);
            border-color: rgba(30, 120, 255, 0.35);
        }

        .cta {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding-bottom: 12px;
            border-bottom: 2.5px solid rgba(255, 255, 255, 0.95);
            font-size: 12.5px;
            font-weight: 700;
            letter-spacing: 2px;
            text-decoration: none;
            color: #fff;
            transition: all 0.3s ease;
            margin-bottom: 50px;
        }

            .cta:hover {
                padding-left: 10px;
                border-bottom-color: #fff;
            }

            .cta svg {
                transition: transform 0.3s ease;
            }

            .cta:hover svg {
                transform: translateX(5px);
            }

        /* Footer */
        .footer {
            margin-top: auto;
        }

        .tap-hint {
            font-size: 13px;
            opacity: 0.58;
            margin-bottom: 18px;
            letter-spacing: 0.2px;
        }

        .info {
            font-size: 12px;
            line-height: 1.7;
            opacity: 0.48;
            letter-spacing: 0.15px;
        }

            .info p {
                margin-bottom: 2px;
            }

        /* Responsive */
        @@media (max-width: 1024px) {
            .title

        {
            font-size: 48px;
        }

        .panel-inner {
            padding: 38px 45px;
        }

        .header-container {
            padding: 0 30px;
        }

        }

        @@media (max-width: 768px) {
            .nav-toggle

        {
            display: flex;
        }

        .nav-menu {
            position: fixed;
            top: 70px;
            right: -100%;
            width: 280px;
            height: calc(100vh - 70px);
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(12px);
            flex-direction: column;
            padding: 30px;
            gap: 25px;
            align-items: flex-start;
            transition: right 0.3s ease;
            border-left: 1px solid rgba(255, 255, 255, 0.08);
        }

            .nav-menu.active {
                right: 0;
            }

        .split-screen {
            flex-direction: column;
        }

        .panel {
            min-height: calc(100vh - 70px);
        }

        .panel-cowork {
            border-left: none;
            border-top: 1px solid rgba(255, 255, 255, 0.12);
        }

        .title {
            font-size: 44px;
        }

        .description {
            font-size: 14px;
        }

        .panel-inner {
            padding: 35px 30px;
        }

        .header {
            margin-bottom: 50px;
        }

        .header-container {
            padding: 0 24px;
        }

        }

        @@media (max-width: 480px) {
            .title

        {
            font-size: 38px;
        }

        .description {
            font-size: 13px;
        }

        .panel-inner {
            padding: 30px 24px;
        }

        .header {
            margin-bottom: 45px;
        }

        .tags {
            gap: 8px;
        }

        .tag {
            padding: 9px 16px;
            font-size: 10px;
        }

        .logo-text {
            font-size: 16px;
        }

        .header-container {
            padding: 0 20px;
        }

        }

        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.3);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 5px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: rgba(255, 255, 255, 0.3);
            }

        /* Contact Section */
        .contact-section {
            background: #0a0a0a;
            padding: 100px 40px;
            position: relative;
        }

            .contact-section::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 1px;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            }

        .contact-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .contact-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: start;
        }

        .contact-title {
            font-family: 'Libre Baskerville', serif;
            font-size: 48px;
            font-weight: 400;
            margin-bottom: 16px;
            color: #fff;
        }

        .contact-subtitle {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.6);
            margin-bottom: 50px;
            line-height: 1.6;
        }

        .contact-details {
            display: flex;
            flex-direction: column;
            gap: 35px;
            margin-bottom: 50px;
        }

        .contact-item {
            display: flex;
            gap: 20px;
            align-items: start;
        }

        .contact-icon {
            width: 48px;
            height: 48px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

            .contact-icon svg {
                color: rgba(255, 255, 255, 0.8);
            }

        .contact-text h4 {
            font-size: 15px;
            font-weight: 600;
            color: #fff;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .contact-text p {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.6);
            line-height: 1.7;
        }

        .contact-text a {
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .contact-text a:hover {
                color: #fff;
            }

        .social-links {
            display: flex;
            gap: 15px;
        }

        .social-link {
            width: 44px;
            height: 44px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255, 255, 255, 0.7);
            transition: all 0.3s ease;
        }

            .social-link:hover {
                background: rgba(255, 255, 255, 0.1);
                border-color: rgba(255, 255, 255, 0.2);
                color: #fff;
                transform: translateY(-2px);
            }

            .social-link svg {
                width: 20px;
                height: 20px;
            }

        /* Contact Form */
        .contact-form-wrapper {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            padding: 45px;
            backdrop-filter: blur(10px);
        }

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

            .form-group label {
                font-size: 13px;
                font-weight: 500;
                color: rgba(255, 255, 255, 0.8);
                letter-spacing: 0.5px;
            }

            .form-group input,
            .form-group select,
            .form-group textarea {
                width: 100%;
                padding: 14px 18px;
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.12);
                border-radius: 8px;
                color: #fff;
                font-size: 14px;
                font-family: 'Inter', sans-serif;
                transition: all 0.3s ease;
            }

                .form-group input:focus,
                .form-group select:focus,
                .form-group textarea:focus {
                    outline: none;
                    border-color: rgba(255, 255, 255, 0.3);
                    background: rgba(255, 255, 255, 0.08);
                }

                .form-group input::placeholder,
                .form-group textarea::placeholder {
                    color: rgba(255, 255, 255, 0.3);
                }

            .form-group select {
                cursor: pointer;
            }

                .form-group select option {
                    background: #1a1a1a;
                    color: #fff;
                }

            .form-group textarea {
                resize: vertical;
                min-height: 120px;
            }

        .submit-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            padding: 16px 32px;
            background: #fff;
            color: #000;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }

            .submit-btn:hover {
                background: rgba(255, 255, 255, 0.9);
                transform: translateY(-2px);
                box-shadow: 0 10px 30px rgba(255, 255, 255, 0.2);
            }

            .submit-btn svg {
                transition: transform 0.3s ease;
            }

            .submit-btn:hover svg {
                transform: translateX(3px);
            }

        /* Footer */
        .footer {
            background: #000;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            padding: 28px 40px;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .footer-content {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 60px;
            margin-bottom: 50px;
        }

        .footer-brand {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .footer-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: #fff;
            font-weight: 600;
            font-size: 20px;
            margin-bottom: 5px;
        }

            .footer-logo .logo-icon {
                font-size: 26px;
            }

        .footer-tagline {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.5);
            font-style: italic;
        }

        .footer-links h4,
        .footer-contact h4 {
            font-size: 14px;
            font-weight: 600;
            color: #fff;
            margin-bottom: 20px;
            letter-spacing: 0.5px;
        }

        .footer-links ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .footer-links a {
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s ease;
        }

            .footer-links a:hover {
                color: #fff;
            }

        .footer-contact p {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.6);
            line-height: 1.8;
            margin-bottom: 5px;
        }

        .footer-bottom {
            padding-top: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            text-align: center;
        }

            .footer-bottom p {
                font-size: 13px;
                color: rgba(255, 255, 255, 0.4);
            }

        /* Contact Section Responsive */
        @@media (max-width: 968px) {
            .contact-content

        {
            grid-template-columns: 1fr;
            gap: 60px;
        }

        .contact-form-wrapper {
            padding: 35px;
        }

        .footer-content {
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        .footer-brand {
            grid-column: 1 / -1;
        }

        }

        @@media (max-width: 640px) {
            .contact-section

        {
            padding: 70px 24px;
        }

        .contact-title {
            font-size: 36px;
        }

        .contact-form-wrapper {
            padding: 28px;
        }

        .footer {
            padding: 50px 24px 25px;
        }

        .footer-content {
            grid-template-columns: 1fr;
            gap: 35px;
        }

        }</style>
</head>
<body>
    <!-- Header -->
    <header class="header header-solid">
        <div class="header-container">
            <a href="/" class="logo">
                <span class="logo-icon">&#9827;</span>
                <span class="logo-text">Brew & Work</span>
            </a>
            <nav class="nav">
                <button class="nav-toggle" aria-label="Toggle navigation" onclick="toggleMenu()">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <ul class="nav-menu" id="navMenu">
                    <li><a asp-controller="Pages" asp-action="Index"class="nav-link active">Home</a></li>
                    <li><a asp-controller="Pages" asp-action="Cafe"  class="nav-link">Cafe</a></li>
                    <li><a asp-controller="Pages" asp-action="Coworking" class="nav-link">Co-Working</a></li>
                    <li><a href="#contact" class="nav-link">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>
    <div class="split-screen">
        <!-- Cafe Panel -->
        <div class="panel panel-cafe" id="cafe">
            <div class="panel-inner">
                <div class="content">
                    <h1 class="title">Coffee for<br>the truly<br>hungry</h1>

                    <p class="description">
                        Specialty coffee, honest food, and a<br>
                        warm industrial space right next to mill.<br>
                        Step in for expresso, stay for<br>
                        conversations.
                    </p>

                    <a asp-controller="Pages" asp-action="Cafe" class="cta">
                        EXPLORE CAFÉ
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="12 5 19 12 12 19"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <!-- Co-Work Panel -->
        <div class="panel panel-cowork" id="coworking">
            <div class="panel-inner">
                <div class="content">
                    <h1 class="title">Work where<br>the energy<br>is real</h1>

                    <p class="description">
                        Work inside and step out to reset.<br>
                        A focused cowork space paired<br>
                        with a modern cafe, built for<br>
                        people who want both productivity<br>
                        and comfort.
                    </p>

                    <a asp-controller="Pages" asp-action="Coworking" class="cta">
                        EXPLORE CO-WORK
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="12 5 19 12 12 19"/>
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <partial name="_Contact" />

    <!-- Footer -->
    <partial name="_Footer" />

    <script>
        function toggleMenu() {
            const navMenu = document.getElementById('navMenu');
            navMenu.classList.toggle('active');
        }

        // Close menu when clicking on a link
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', () => {
                document.getElementById('navMenu').classList.remove('active');
            });
        });

        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Contact form submission
        document.querySelector('.contact-form').addEventListener('submit', function(e) {
            e.preventDefault();

            // Get form data
            const formData = new FormData(this);
            const data = Object.fromEntries(formData);

            // Here you would typically send the data to your backend
            console.log('Form submitted:', data);

            // Show success message (you can customize this)
            alert('Thank you for your message! We\'ll get back to you soon.');

            // Reset form
            this.reset();
        });
    </script>

    <script src="~/js/main.js"></script>
</body>

